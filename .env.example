# Runtime
NODE_ENV=production
PORT=3000
DEBUG=false
SHOPIFY_SESSION_DB_PATH=./data/shopify_sessions.sqlite

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://import-stock.woora.fr
# APP_URL can be used as fallback when SHOPIFY_APP_URL is not set.
# APP_URL=https://import-stock.woora.fr
SCOPES=read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_inventory,read_locations,read_products,write_inventory
SHOP_CUSTOM_DOMAIN=
SHOP=wearmoi-dev.myshopify.com

# Prestashop
PRESTA_BASE_URL=https://btob.wearmoi.com
PRESTA_ALLOWED_HOST=btob.wearmoi.com
PRESTA_WS_KEY=
PRESTA_BOUTIQUE_CUSTOMER_ID=21749

# App behavior
SHOPIFY_DEFAULT_LOCATION_NAME=Boutique Toulon
SYNC_BATCH_SIZE=50
SYNC_MAX_PER_RUN=200

# Cron
# Generate one with: npm run cron:secret
CRON_SECRET=
