{
  "name": "wear-moi-stock-sync",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev -c shopify.app.toml",
    "dev:classic": "shopify app dev -c shopify.app.import-stock-boutique.toml",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "node --env-file=.env ./node_modules/@react-router/serve/dist/cli.js ./build/server/index.js",
    "start:plain": "react-router-serve ./build/server/index.js",
    "start:prod": "node --env-file=.env ./node_modules/@react-router/serve/dist/cli.js ./build/server/index.js",
    "prepare:vps": "powershell -ExecutionPolicy Bypass -File scripts/prepare-vps.ps1",
    "cron:secret": "node scripts/generate-cron-secret.mjs",
    "deploy:vps:v1:hint": "echo \"On VPS: sudo APP_DIR=/var/www/import-stock-v1 DOMAIN=<domain> APP_PORT=3001 ./scripts/deploy_vps_v1.sh\"",
    "cron:v1:hint": "echo \"On VPS: sudo SHOP=<shop> LOCATION_ID=<gid> CRON_SECRET=<secret> APP_URL=https://<domain> ./scripts/install_cron_v1.sh\"",
    "redeploy:vps:hint": "echo \"On VPS: chmod +x scripts/redeploy_vps.sh && ./scripts/redeploy_vps.sh\"",
    "docker-start": "npm run start",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/**/*.test.ts"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/polaris": "^13.9.5",
    "@shopify/polaris-icons": "^9.3.1",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-sqlite": "^5.0.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "fast-xml-parser": "^5.4.1",
    "isbot": "^5.1.31",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "sqlite3": "^5.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.6"
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "Thomas"
}
